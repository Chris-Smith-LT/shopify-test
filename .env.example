PORT=3000
APP_URL=""                          # Public HTTPS URL — ngrok locally, cloud URL in production
SHOPIFY_CLIENT_ID=""                # From Dev Dashboard app
SHOPIFY_CLIENT_SECRET=""            # From Dev Dashboard app
SHOPIFY_SCOPES="write_shipping,read_orders"
SHOPIFY_SHOP_DOMAIN=""              # Bare domain only — e.g. my-store.myshopify.com (NO https://)
SHOPIFY_ACCESS_TOKEN=""             # Written automatically by OAuth flow (/auth?shop=...)

# Optional overrides
LTL_MIN_WEIGHT_GRAMS=68039          # LTL eligibility threshold — default 150 lbs
TMS_TIMEOUT_MS=7000                 # TMS call timeout — returns { "rates": [] } on breach
CACHE_TTL_MS=1200000                # Rate cache TTL in ms — default 20 minutes
LOG_LEVEL=info                      # Pino log level: trace | debug | info | warn | error
